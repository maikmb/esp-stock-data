menu "Stock Ticker Configuration"

    menu "WiFi"

        config ESP_WIFI_SSID
            string "WiFi SSID (first-boot fallback)"
            default "myssid"
            help
                SSID (network name) to connect to when no network has been
                configured from the on-screen WiFi panel yet. Networks picked
                on the touch screen are saved to NVS and take priority over
                this value. May be left empty to always configure on-screen.

        config ESP_WIFI_PASSWORD
            string "WiFi Password (first-boot fallback)"
            default "mypassword"
            help
                WiFi password (WPA2/WPA3) for ESP_WIFI_SSID. Like the SSID,
                only used until a network is configured on-screen (stored in
                NVS namespace "wifi_cfg").

        config ESP_MAXIMUM_RETRY
            int "Fast retry attempts before backoff"
            default 5
            help
                Number of quick reconnect attempts before the device switches
                to a slower retry interval. The device never gives up
                permanently -- it keeps retrying in the background so the
                screen recovers automatically once the AP is back.

    endmenu

    menu "Market Data API"

        config MARKET_ALPHA_VANTAGE_API_KEY
            string "Alpha Vantage API key"
            default ""
            help
                Free key from https://www.alphavantage.co/support/#api-key.
                Required for stock quotes (CONFIG_MARKET_STOCK_SYMBOLS).
                Crypto quotes via CoinGecko do not need a key.

        config MARKET_CRYPTO_IDS
            string "CoinGecko coin IDs (comma separated)"
            default "bitcoin,ethereum"
            help
                CoinGecko API coin ids, e.g. "bitcoin,ethereum,solana".
                Find ids at https://api.coingecko.com/api/v3/coins/list

        config MARKET_STOCK_SYMBOLS
            string "Stock ticker symbols (comma separated)"
            default "AAPL,MSFT"
            help
                Stock symbols to query via Alpha Vantage GLOBAL_QUOTE,
                e.g. "AAPL,MSFT,PETR4.SAO". Leave empty to show crypto only.

        config MARKET_REFRESH_INTERVAL_SEC
            int "Refresh interval (seconds)"
            default 60
            range 15 3600
            help
                How often to re-fetch prices. Alpha Vantage's free tier is
                rate-limited (25 requests/day as of 2026), so keep this high
                if you track several stock symbols.

    endmenu

endmenu
